      elements.complaintSubmitText = document.getElementById("complaintSubmitText");
      elements.complaintSpinner = document.getElementById("complaintSpinner");
      elements.complaintSubmitButton = document.getElementById("complaintSubmitButton");
    }

    function applyTheme(config) {
      const background = config.background_color || defaultConfig.background_color;
      const surface = config.surface_color || defaultConfig.surface_color;
      const text = config.text_color || defaultConfig.text_color;
      const primary = config.primary_action_color || defaultConfig.primary_action_color;
      const secondary = config.secondary_action_color || defaultConfig.secondary_action_color;
      const font = config.font_family || defaultConfig.font_family;
      const base = Number(config.font_size || defaultConfig.font_size);

      document.documentElement.style.setProperty("--background-color", background);
      document.documentElement.style.setProperty("--surface-color", surface);
      document.documentElement.style.setProperty("--text-color", text);
      document.documentElement.style.setProperty("--primary-action", primary);
      document.documentElement.style.setProperty("--secondary-action", secondary);

      document.body.style.background = `
        radial-gradient(circle at 20% 20%, ${hexToRgba(primary, 0.28)}, transparent 26%),
        radial-gradient(circle at 80% 10%, ${hexToRgba(secondary, 0.14)}, transparent 24%),
        radial-gradient(circle at 50% 80%, ${hexToRgba(primary, 0.18)}, transparent 28%),
        linear-gradient(145deg, #040b16 0%, ${hexToRgba(background, 0.96)} 40%, #0a1730 100%)
      `;

      document.querySelectorAll(".glass").forEach((card) => {
        card.style.background = `linear-gradient(180deg, ${hexToRgba(surface, 0.88)}, rgba(10,20,36,0.78))`;
        card.style.borderColor = hexToRgba(secondary, 0.16);
      });

      document.querySelectorAll(".section-title, .stat-number, h1, h2, h3").forEach((el) => {
        el.style.fontFamily = `${font}, "Manrope", sans-serif`;
      });

      document.querySelectorAll("body, p, a, button, input, textarea, span, label").forEach((el) => {
        el.style.fontFamily = `${font}, "Manrope", sans-serif`;
      });

      elements.heroTitle.style.fontSize = `${base * 3.2}px`;
      elements.heroSubtitle.style.fontSize = `${base * 1.1}px`;
      document.querySelectorAll(".section-title").forEach((el) => {
        el.style.fontSize = `${base * 2.1}px`;
      });
      document.querySelectorAll("p, label, input, textarea, button, a").forEach((el) => {
        if (!el.classList.contains("section-title")) {
          el.style.fontSize = `${base}px`;
        }
      });

      elements.programButton.style.background = `linear-gradient(135deg, ${primary}, ${secondary})`;
      elements.programButton.style.color = "#ffffff";
      elements.communitySubmitButton.style.background = `linear-gradient(135deg, ${primary}, ${secondary})`;
      elements.communitySubmitButton.style.color = "#ffffff";
      elements.complaintSubmitButton.style.background = `linear-gradient(135deg, ${primary}, ${secondary})`;
      elements.complaintSubmitButton.style.color = "#ffffff";

      document.querySelectorAll(".text-sky-300").forEach((el) => {
        el.style.color = secondary;
      });
    }

    function hexToRgba(hex, alpha) {
      const clean = hex.replace("#", "");
      const full = clean.length === 3 ? clean.split("").map((c) => c + c).join("") : clean;
      const bigint = parseInt(full, 16);
      const r = (bigint >> 16) & 255;
      const g = (bigint >> 8) & 255;
      const b = bigint & 255;
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    async function onConfigChange(config) {
      elements.heroTitle.textContent = config.hero_title || defaultConfig.hero_title;
      elements.heroSubtitle.textContent = config.hero_subtitle || defaultConfig.hero_subtitle;
      elements.programButton.querySelector("span").textContent = config.program_button_text || defaultConfig.program_button_text;
      elements.communityButton.querySelector("span").textContent = config.community_button_text || defaultConfig.community_button_text;
      elements.whyTitle.textContent = config.why_title || defaultConfig.why_title;
      elements.skillsTitle.textContent = config.skills_title || defaultConfig.skills_title;
      elements.practicalTitle.textContent = config.practical_title || defaultConfig.practical_title;
      elements.modulesTitle.textContent = config.modules_title || defaultConfig.modules_title;
      elements.communityTitle.textContent = config.community_title || defaultConfig.community_title;
      elements.complaintTitle.textContent = config.complaint_title || defaultConfig.complaint_title;
      elements.footerText.textContent = config.footer_text || defaultConfig.footer_text;
      applyTheme(config);
    }

    function initElementSdk() {
      if (!window.elementSdk) return;

      window.elementSdk.init({
        defaultConfig,
        onConfigChange,
        mapToCapabilities: (config) => ({
          recolorables: [
            {
              get: () => config.background_color || defaultConfig.background_color,
              set: (value) => window.elementSdk.setConfig({ background_color: value })
            },
            {
              get: () => config.surface_color || defaultConfig.surface_color,
              set: (value) => window.elementSdk.setConfig({ surface_color: value })
            },
            {
              get: () => config.text_color || defaultConfig.text_color,
              set: (value) => window.elementSdk.setConfig({ text_color: value })
            },
            {
              get: () => config.primary_action_color || defaultConfig.primary_action_color,
              set: (value) => window.elementSdk.setConfig({ primary_action_color: value })
            },
            {
              get: () => config.secondary_action_color || defaultConfig.secondary_action_color,
              set: (value) => window.elementSdk.setConfig({ secondary_action_color: value })
            }
          ],
          borderables: [],
          fontEditable: {
            get: () => config.font_family || defaultConfig.font_family,
            set: (value) => window.elementSdk.setConfig({ font_family: value })
          },
          fontSizeable: {
            get: () => config.font_size || defaultConfig.font_size,
            set: (value) => window.elementSdk.setConfig({ font_size: value })
          }
        }),
        mapToEditPanelValues: (config) => new Map([
          ["hero_title", config.hero_title || defaultConfig.hero_title],
          ["hero_subtitle", config.hero_subtitle || defaultConfig.hero_subtitle],
          ["program_button_text", config.program_button_text || defaultConfig.program_button_text],
          ["community_button_text", config.community_button_text || defaultConfig.community_button_text],
          ["why_title", config.why_title || defaultConfig.why_title],
          ["skills_title", config.skills_title || defaultConfig.skills_title],
          ["practical_title", config.practical_title || defaultConfig.practical_title],
          ["modules_title", config.modules_title || defaultConfig.modules_title],
          ["community_title", config.community_title || defaultConfig.community_title],
          ["complaint_title", config.complaint_title || defaultConfig.complaint_title],
          ["footer_text", config.footer_text || defaultConfig.footer_text]
        ])
      });

      onConfigChange(window.elementSdk.config || defaultConfig);
    }

    function showMessage(el, message) {
      el.textContent = message;
      el.classList.remove("hidden");
    }

    function hideMessage(el) {
      el.textContent = "";
      el.classList.add("hidden");
    }

    function validateEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function setComplaintLoading(loading) {
      state.complaintSubmitting = loading;
      elements.complaintSubmitButton.disabled = loading;
      elements.complaintSubmitButton.classList.toggle("opacity-70", loading);
      elements.complaintSubmitButton.classList.toggle("cursor-not-allowed", loading);
      elements.complaintSpinner.classList.toggle("hidden", !loading);
      elements.complaintSubmitText.textContent = loading ? "Envoi..." : "Envoyer le message";
    }

    function setCommunityLoading(loading) {
      state.communitySubmitting = loading;
      elements.communitySubmitButton.disabled = loading;
      elements.communitySubmitButton.classList.toggle("opacity-70", loading);
      elements.communitySubmitButton.classList.toggle("cursor-not-allowed", loading);
      elements.communitySpinner.classList.toggle("hidden", !loading);
      elements.communitySubmitText.textContent = loading
        ? "Publication..."
        : (elements.communityParentId.value ? "Répondre au message" : "Publier dans la communauté");
    }

    function checkLimitBeforeCreate() {
      hideMessage(elements.dataLimitWarning);
      if (state.records.length >= 999) {
        showMessage(elements.dataLimitWarning, "Limite maximale atteinte. Veuillez supprimer certains éléments avant d'en ajouter d'autres.");
        return false;
      }
      if (state.records.length >= 950) {
        showMessage(elements.dataLimitWarning, "Vous approchez de la limite de stockage. Envisagez de supprimer les éléments plus anciens si nécessaire.");
      }
      return true;
    }

    async function handleComplaintSubmit(event) {
      event.preventDefault();
      hideMessage(elements.complaintError);
      hideMessage(elements.complaintSuccess);

      const name = document.getElementById("complaintName").value.trim();
      const email = document.getElementById("complaintEmail").value.trim();
      const message = document.getElementById("complaintMessage").value.trim();

      if (!name || !email || !message) {
        showMessage(elements.complaintError, "Veuillez remplir tous les champs.");
        return;
      }

      if (!validateEmail(email)) {
        showMessage(elements.complaintError, "Veuillez entrer une adresse email valide.");
        return;
      }

      if (!window.dataSdk) {
        showMessage(elements.complaintError, "La sauvegarde n'est pas disponible en ce moment.");
        return;
      }

      if (!checkLimitBeforeCreate()) return;

      setComplaintLoading(true);
      const result = await window.dataSdk.create({
        type: "complaint",
        author_name: name,
        author_email: email,
        message: message,
        created_at: new Date().toISOString(),
        parent_id: ""
      });

      setComplaintLoading(false);

      if (result.isOk) {
        document.getElementById("complaintForm").reset();
        showMessage(elements.complaintSuccess, "Votre message a été envoyé avec succès.");
      } else {
        showMessage(elements.complaintError, "Une erreur s'est produite lors de la sauvegarde de votre message. Veuillez réessayer.");
      }
    }

    async function handleCommunitySubmit(event) {
      event.preventDefault();
      hideMessage(elements.communityError);
      hideMessage(elements.communitySuccess);

      const name = document.getElementById("communityName").value.trim();
      const email = document.getElementById("communityEmail").value.trim();
      const message = document.getElementById("communityMessage").value.trim();
      const parentId = elements.communityParentId.value;

      if (!name || !email || !message) {
        showMessage(elements.communityError, "Veuillez remplir tous les champs avant de publier.");
        return;
      }

      if (!validateEmail(email)) {
        showMessage(elements.communityError, "Veuillez entrer une adresse email valide.");
        return;
      }

      if (!window.dataSdk) {
        showMessage(elements.communityError, "La sauvegarde n'est pas disponible en ce moment.");
        return;
      }

      if (!checkLimitBeforeCreate()) return;

      setCommunityLoading(true);
      const result = await window.dataSdk.create({
        type: "community",
        author_name: name,
        author_email: email,
        message: message,
        created_at: new Date().toISOString(),
        parent_id: parentId || ""
      });
      setCommunityLoading(false);

      if (result.isOk) {
        document.getElementById("communityForm").reset();
        elements.communityParentId.value = "";
        elements.communityCancelReply.classList.add("hidden");
        setCommunityLoading(false);
        showMessage(elements.communitySuccess, parentId ? "Votre réponse a été publiée." : "Votre message a été publié.");
      } else {
        showMessage(elements.communityError, "Une erreur s'est produite lors de la publication. Veuillez réessayer.");
      }
    }

    function createForumItem(record, replies) {
      const wrapper = document.createElement("article");
      wrapper.className = "forum-item rounded-[1.5rem] border border-white/10 bg-white/5 p-5";
      wrapper.dataset.backendId = record.__backendId;

      const date = new Date(record.created_at);
      const readableDate = isNaN(date.getTime()) ? "Récemment" : date.toLocaleDateString("fr-FR", { year: "numeric", month: "short", day: "numeric" });

      wrapper.innerHTML = `
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-3">
              <span class="rounded-full bg-sky-300/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-200">Étudiant</span>
              <span class="text-xs text-sky-50/55">${readableDate}</span>
            </div>
            <h4 class="mt-3 font-['Sora'] text-lg font-bold text-white">${escapeHtml(record.author_name || "Étudiant")}</h4>
            <p class="mt-3 whitespace-pre-wrap text-sm leading-7 text-sky-50/76">${escapeHtml(record.message || "")}</p>
          </div>
          <div class="flex flex-row gap-2 sm:flex-col">
            <button type="button" class="reply-btn rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-sky-100 hover:bg-white/10">Répondre</button>
            <button type="button" class="delete-btn rounded-xl border border-red-400/15 bg-red-500/10 px-4 py-2 text-sm font-semibold text-red-100 hover:bg-red-500/15">Supprimer</button>
          </div>
        </div>
        <div class="confirm-delete hidden mt-4 rounded-2xl border border-amber-400/20 bg-amber-500/10 p-4">
          <p class="text-sm text-amber-100">Supprimer ce message ?</p>
          <div class="mt-3 flex gap-2">
            <button type="button" class="confirm-delete-btn rounded-xl bg-red-500/80 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500">Oui, supprimer</button>
            <button type="button" class="cancel-delete-btn rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-sky-50 hover:bg-white/10">Annuler</button>
          </div>
        </div>
        <div class="replies mt-4 space-y-3"></div>
      `;

      const repliesContainer = wrapper.querySelector(".replies");
      replies.forEach((reply) => {
        repliesContainer.appendChild(createReplyItem(reply));
      });

      wrapper.querySelector(".reply-btn").addEventListener("click", () => {
        elements.communityParentId.value = record.__backendId;
        elements.communityCancelReply.classList.remove("hidden");
        document.getElementById("communityMessage").focus();
        hideMessage(elements.communitySuccess);
        hideMessage(elements.communityError);
        setCommunityLoading(false);
        elements.communitySubmitText.textContent = "Répondre au message";
      });

      const confirmBox = wrapper.querySelector(".confirm-delete");
      wrapper.querySelector(".delete-btn").addEventListener("click", () => {
        confirmBox.classList.remove("hidden");
      });

      wrapper.querySelector(".cancel-delete-btn").addEventListener("click", () => {
        confirmBox.classList.add("hidden");
      });

      wrapper.querySelector(".confirm-delete-btn").addEventListener("click", async () => {
        await deleteRecord(record);
      });

      return wrapper;
    }

    function createReplyItem(record) {
      const reply = document.createElement("div");
      reply.className = "ml-0 rounded-2xl border border-white/10 bg-[#0a1728] p-4 sm:ml-8";
      reply.dataset.backendId = record.__backendId;

      const date = new Date(record.created_at);
      const readableDate = isNaN(date.getTime()) ? "Récemment" : date.toLocaleDateString("fr-FR", { month: "short", day: "numeric" });

      reply.innerHTML = `
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="font-semibold text-white">${escapeHtml(record.author_name || "Étudiant")}</p>
            <p class="mt-1 text-xs text-sky-50/50">${readableDate}</p>
          </div>
          <button type="button" class="delete-reply-btn rounded-xl border border-red-400/15 bg-red-500/10 px-3 py-2 text-xs font-semibold text-red-100 hover:bg-red-500/15">Supprimer</button>
        </div>
        <p class="mt-3 whitespace-pre-wrap text-sm leading-7 text-sky-50/72">${escapeHtml(record.message || "")}</p>
        <div class="confirm-delete-reply hidden mt-3 rounded-2xl border border-amber-400/20 bg-amber-500/10 p-3">
          <p class="text-sm text-amber-100">Supprimer cette réponse ?</p>
          <div class="mt-3 flex gap-2">
            <button type="button" class="confirm-delete-reply-btn rounded-xl bg-red-500/80 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500">Oui</button>
            <button type="button" class="cancel-delete-reply-btn rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-sky-50 hover:bg-white/10">Annuler</button>
          </div>
        </div>
      `;

      const confirmBox = reply.querySelector(".confirm-delete-reply");
      reply.querySelector(".delete-reply-btn").addEventListener("click", () => {
        confirmBox.classList.remove("hidden");
      });
      reply.querySelector(".cancel-delete-reply-btn").addEventListener("click", () => {
        confirmBox.classList.add("hidden");
      });
      reply.querySelector(".confirm-delete-reply-btn").addEventListener("click", async () => {
        await deleteRecord(record);
      });

      return reply;
    }

    async function deleteRecord(record) {
      hideMessage(elements.communityError);
      hideMessage(elements.communitySuccess);

      if (!window.dataSdk) {
        showMessage(elements.communityError, "La suppression n'est pas disponible en ce moment.");
        return;
      }

      const result = await window.dataSdk.delete(record);
      if (result.isOk) {
        showMessage(elements.communitySuccess, "Élément supprimé avec succès.");
      } else {
        showMessage(elements.communityError, "Une erreur s'est produite lors de la suppression. Veuillez réessayer.");
      }
    }

    function syncCommunityUI() {
      const posts = state.records
        .filter((record) => record.type === "community" && !record.parent_id)
        .sort((a, b) => new Date(b.created_at) - new Date(a.created_at));

      const replies = state.records
        .filter((record) => record.type === "community" && record.parent_id);

      const existing = new Map(Array.from(elements.communityList.children).map((el) => [el.dataset.backendId, el]));
      const activeIds = new Set();

      posts.forEach((post) => {
        activeIds.add(post.__backendId);
        const postReplies = replies
          .filter((reply) => reply.parent_id === post.__backendId)
          .sort((a, b) => new Date(a.created_at) - new Date(b.created_at));

        let item = existing.get(post.__backendId);
        if (!item) {
          item = createForumItem(post, postReplies);
          elements.communityList.appendChild(item);
        } else {
          const newItem = createForumItem(post, postReplies);
          elements.communityList.replaceChild(newItem, item);
        }
      });

      existing.forEach((el, id) => {
        if (!activeIds.has(id)) {
          el.remove();
        }
      });

      elements.communityEmpty.classList.toggle("hidden", posts.length > 0);
      const communityCount = state.records.filter((record) => record.type === "community").length;
      elements.communityCount.textContent = `${communityCount} ${communityCount === 1 ? "publication" : "publications"}`;
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    async function initDataSdk() {
      if (!window.dataSdk) return;

      const handler = {
        onDataChanged(data) {
          state.records = data.slice();
          syncCommunityUI();
          checkLimitBeforeCreate();
        }
      };

      const initResult = await window.dataSdk.init(handler);
      if (!initResult.isOk) {
        showMessage(elements.communityError, "L'espace de discussion n'a pas pu se connecter aux données sauvegardées.");
      }
    }

    function initScrollReveal() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
          }
        });
      }, { threshold: 0.15 });

      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    }

    function initNewsSlider() {
      const slides = Array.from(document.querySelectorAll(".news-slide"));
      let index = 0;

      function showSlide(nextIndex) {
        slides[index].classList.remove("active");
        index = (nextIndex + slides.length) % slides.length;
        slides[index].classList.add("active");
      }

      document.getElementById("nextNews").addEventListener("click", () => showSlide(index + 1));
      document.getElementById("prevNews").addEventListener("click", () => showSlide(index - 1));

      setInterval(() => showSlide(index + 1), 5000);
    }

    function initStats() {
      const stats = document.querySelectorAll("[data-target]");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const target = Number(el.getAttribute("data-target"));
          let current = 0;
          const step = Math.max(1, Math.floor(target / 40));
          const timer = setInterval(() => {
            current += step;
            if (current >= target) {
              current = target;
              clearInterval(timer);
            }
            el.textContent = `${current}${target === 85 ? "%" : "+"}`.replace("6+", "6");
          }, 32);
          observer.unobserve(el);
        });
      }, { threshold: 0.5 });

      stats.forEach((el) => observer.observe(el));
    }

    function initNav() {
      const button = document.getElementById("mobileMenuButton");
      const menu = document.getElementById("mobileMenu");
      button.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });

      menu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => menu.classList.add("hidden"));
      });
    }

    function initForms() {
      document.getElementById("complaintForm").addEventListener("submit", handleComplaintSubmit);
      document.getElementById("communityForm").addEventListener("submit", handleCommunitySubmit);
      elements.communityCancelReply.addEventListener("click", () => {
        elements.communityParentId.value = "";
        elements.communityCancelReply.classList.add("hidden");
        elements.communitySubmitText.textContent = "Publier dans la communauté";
      });
    }

    function initAudio() {
      const playButton = document.getElementById("videoPlayButton");
      playButton.addEventListener("click", () => {
        if (!state.audioContext) {
          state.audioContext = new (window.AudioContext || window.webkitAudioContext)();
        }
        const ctx = state.audioContext;
        const oscillator = ctx.createOscillator();
        const gainNode = ctx.createGain();
        oscillator.type = "sine";
        oscillator.frequency.setValueAtTime(440, ctx.currentTime);
        oscillator.frequency.linearRampToValueAtTime(660, ctx.currentTime + 0.4);
        oscillator.frequency.linearRampToValueAtTime(520, ctx.currentTime + 0.8);
        gainNode.gain.setValueAtTime(0.0001, ctx.currentTime);
        gainNode.gain.linearRampToValueAtTime(0.06, ctx.currentTime + 0.08);
        gainNode.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 1.2);
        oscillator.connect(gainNode);
        gainNode.connect(ctx.destination);
        oscillator.start();
        oscillator.stop(ctx.currentTime + 1.2);
      });
    }

    function initIcons() {
      if (window.lucide) {
        window.lucide.createIcons();
      }
    }

    setupElements();
    initElementSdk();
    initDataSdk();
    initScrollReveal();
    initNewsSlider();
    initStats();
    initNav();
    initForms();
    initAudio();
    initIcons();
  </script>
