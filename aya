    function getConfigValue(key) {
      if (window.elementSdk && window.elementSdk.config && window.elementSdk.config[key] !== undefined && window.elementSdk.config[key] !== null && window.elementSdk.config[key] !== "") {
        return window.elementSdk.config[key];
      }
      return defaultConfig[key];
    }

    function setupElements() {
      elements.heroTitle = document.getElementById("heroTitle");
      elements.heroSubtitle = document.getElementById("heroSubtitle");
